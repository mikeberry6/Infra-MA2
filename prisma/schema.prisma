generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ── Shared Enums ────────────────────────────────────────

enum RecordStatus {
  DRAFT
  IN_REVIEW
  PUBLISHED
  ARCHIVED
}

enum UserRole {
  ADMIN
  ANALYST
  SUBSCRIBER
  PUBLIC
}

// ── Organization ────────────────────────────────────────

enum OrgType {
  FUND_MANAGER
  CORPORATE
  ADVISOR_FINANCIAL
  ADVISOR_LEGAL
  SOVEREIGN_WEALTH
  PENSION
  OTHER
}

model Organization {
  id           String       @id @default(cuid())
  name         String       @unique
  types        OrgType[]
  website      String?
  headquarters String?
  description  String?
  status       RecordStatus @default(PUBLISHED)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  managedFunds       Fund[]
  dealParticipations DealParticipant[]
  ownershipPeriods   OwnershipPeriod[]
  aliases            Alias[]
  newsMentions       NewsMention[]

  @@index([name])
}

model Alias {
  id             String       @id @default(cuid())
  alias          String       @unique
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])

  @@index([alias])
  @@index([organizationId])
}

// ── Fund ────────────────────────────────────────────────

enum FundStrategy {
  CORE
  CORE_PLUS
  VALUE_ADD
  OPPORTUNISTIC
  GROWTH
  CREDIT_DEBT
  FUND_OF_FUNDS
  SECONDARIES
  CO_INVESTMENTS
  GREENFIELD
  RETAIL_ACT_40
}

enum FundStructure {
  OPEN_END
  CLOSED_END
  PERMANENT_CAPITAL
  EVERGREEN
  LISTED_EVERGREEN
  LISTED_CLOSED_END
}

enum FundStatusEnum {
  EVERGREEN
  FINANCIAL_CLOSE
  RAISING
}

enum FundSectorEnum {
  POWER_ET
  UTILITIES
  DIGITAL
  MIDSTREAM
  TRANSPORTATION
  SOCIAL_INFRA
}

enum FundRegionEnum {
  NORTH_AMERICA
  EUROPE
  ASIA_PACIFIC
  LATIN_AMERICA
  MIDDLE_EAST_AFRICA
  GLOBAL
}

model Fund {
  id                 String           @id @default(cuid())
  legacyId           String           @unique
  managerId          String
  manager            Organization     @relation(fields: [managerId], references: [id])
  fundName           String           @unique
  ticker             String?
  investmentStrategy String           @default("")
  size               String
  sizeUsdMm          Float?
  vintage            String
  strategies         FundStrategy[]
  structure          FundStructure
  fundStatus         FundStatusEnum
  sectors            FundSectorEnum[]
  regions            FundRegionEnum[]
  sourceUrls         String[]
  strategyUrl        String           @default("")
  status             RecordStatus     @default(PUBLISHED)
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt

  ownershipPeriods OwnershipPeriod[]
  newsMentions     NewsMention[]

  @@index([managerId])
  @@index([fundName])
}

// ── Company (Portfolio Company) ─────────────────────────

enum CompanySector {
  POWER_ET
  UTILITIES
  DIGITAL
  MIDSTREAM
  TRANSPORTATION
  SOCIAL_INFRA
}

enum CompanyRegion {
  NORTH_AMERICA
  EUROPE
  ASIA_PACIFIC
  LATIN_AMERICA
  GLOBAL
}

enum CompanyStatus {
  ACTIVE
  REALIZED
}

model Company {
  id            String        @id @default(cuid())
  name          String
  sector        CompanySector
  subsector     String        @default("")
  region        CompanyRegion
  country       String
  countryTags   String[]
  description   String        @default("")
  companyStatus CompanyStatus
  website       String?
  yearFounded   Int?
  headquarters  String?
  status        RecordStatus  @default(PUBLISHED)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  ownershipPeriods OwnershipPeriod[]
  milestones       Milestone[]
  managementRoles  ManagementRole[]
  citations        Citation[]
  newsMentions     NewsMention[]

  @@unique([name, country])
  @@index([name])
  @@index([sector])
}

// ── OwnershipPeriod ─────────────────────────────────────

model OwnershipPeriod {
  id             String        @id @default(cuid())
  fundId         String?
  fund           Fund?         @relation(fields: [fundId], references: [id])
  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id])
  companyId      String
  company        Company       @relation(fields: [companyId], references: [id])
  vehicleName    String?
  stake          String?
  investmentYear Int?
  exitYear       Int?
  isActive       Boolean       @default(true)
  createdAt      DateTime      @default(now())

  @@unique([companyId, organizationId, vehicleName])
  @@index([fundId])
  @@index([organizationId])
  @@index([companyId])
}

// ── Deal ────────────────────────────────────────────────

enum DealSector {
  POWER_ET
  UTILITIES
  DIGITAL
  MIDSTREAM
  TRANSPORTATION
  SOCIAL_INFRA
}

enum DealRegion {
  NORTH_AMERICA
  EUROPE
  ASIA_PACIFIC
  MIDDLE_EAST_AFRICA
  LATIN_AMERICA
}

enum DealCategory {
  ACQUISITION_BUYOUT
  ACQUISITION_MAJORITY_STAKE
  ACQUISITION_MINORITY_STAKE
  ACQUISITION_BOLT_ON
  SALE_BUYOUT
  SALE_MAJORITY_STAKE
  SALE_MINORITY_STAKE
  SALE_CARVE_OUT
  PLATFORM_LAUNCH
  IPO
  JOINT_VENTURE
}

enum DealStatusEnum {
  ANNOUNCED
  CLOSED
  PENDING_REGULATORY_APPROVAL
  TERMINATED
}

model Deal {
  id                String         @id @default(cuid())
  legacyId          String         @unique
  title             String
  target            String
  sector            DealSector
  subsector         String         @default("")
  region            DealRegion
  categories        DealCategory[]
  date              DateTime
  description       String         @default("")
  targetDescription String         @default("")
  country           String         @default("")

  enterpriseValue String?
  equityValue     String?
  stake           String?
  dealStatus      DealStatusEnum
  closingDate     DateTime?

  assetScale        String?
  valuationMultiple String?
  fundVehicle       String?
  keyHighlights     String[]

  status    RecordStatus @default(PUBLISHED)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  participants DealParticipant[]
  citations    Citation[]
  newsMentions NewsMention[]

  @@index([date])
  @@index([sector])
  @@index([region])
  @@index([legacyId])
}

// ── DealParticipant ─────────────────────────────────────

enum ParticipantRole {
  BUYER
  SELLER
  FINANCIAL_ADVISOR_BUYER
  FINANCIAL_ADVISOR_SELLER
  LEGAL_ADVISOR_BUYER
  LEGAL_ADVISOR_SELLER
}

model DealParticipant {
  id             String          @id @default(cuid())
  dealId         String
  deal           Deal            @relation(fields: [dealId], references: [id])
  organizationId String
  organization   Organization    @relation(fields: [organizationId], references: [id])
  role           ParticipantRole
  displayName    String?

  @@unique([dealId, organizationId, role])
  @@index([dealId])
  @@index([organizationId])
}

// ── Milestone ───────────────────────────────────────────

enum MilestoneCategory {
  FOUNDING
  ACQUISITION
  FINANCING
  EXPANSION
  MANAGEMENT
  DIVESTITURE
  IPO
  OTHER
}

model Milestone {
  id        String            @id @default(cuid())
  companyId String
  company   Company           @relation(fields: [companyId], references: [id])
  date      String
  event     String
  category  MilestoneCategory
  sortDate  DateTime?

  @@index([companyId])
}

// ── Person + ManagementRole ─────────────────────────────

model Person {
  id    String           @id @default(cuid())
  name  String
  roles ManagementRole[]

  @@index([name])
}

model ManagementRole {
  id        String    @id @default(cuid())
  personId  String
  person    Person    @relation(fields: [personId], references: [id])
  companyId String
  company   Company   @relation(fields: [companyId], references: [id])
  title     String
  startDate DateTime?
  endDate   DateTime?

  @@index([companyId])
  @@index([personId])
}

// ── Source + Citation ───────────────────────────────────

enum SourceType {
  ARTICLE
  PRESS_RELEASE
  SEC_FILING
  PRESENTATION
  WEBSITE
  OTHER
}

enum CitationPurpose {
  COMPANY_PROFILE
  OWNERSHIP_INVESTMENT
  OPERATIONS_ASSETS
  MILESTONE_EVENT
  FINANCING_FILINGS
  SUPPORTING_CONTEXT
}

model Source {
  id        String     @id @default(cuid())
  label     String
  url       String     @unique
  type      SourceType @default(ARTICLE)
  createdAt DateTime   @default(now())

  citations Citation[]
}

model Citation {
  id            String          @id @default(cuid())
  sourceId      String
  source        Source          @relation(fields: [sourceId], references: [id])
  dealId        String?
  deal          Deal?           @relation(fields: [dealId], references: [id])
  companyId     String?
  company       Company?        @relation(fields: [companyId], references: [id])
  purpose       CitationPurpose @default(SUPPORTING_CONTEXT)
  evidenceLabel String?

  @@index([sourceId])
  @@index([dealId])
  @@index([companyId])
}

// ── News Feed ──────────────────────────────────────────────

enum NewsCategory {
  TRANSACTION_ACTIVITY
  FUNDRAISING_ACTIVITY
  PORTFOLIO_COMPANY_NEWS
  INVESTMENT_FIRM_NEWS
  RUMORED_SALES_PROCESS
  LOW_CONFIDENCE_NEEDS_REVIEW
}

enum NewsMentionType {
  COMPANY
  FUND_MANAGER
  FUND
  DEAL
}

enum NewsConfidence {
  HIGH
  MEDIUM
  LOW
}

model NewsItem {
  id           String         @id @default(cuid())
  legacyId     String?        @unique
  title        String
  summary      String         @default("")
  category     NewsCategory
  sourceName   String         @default("")
  sourceUrl    String?
  linkedinUrls String[]       @default([])
  publishedAt  DateTime
  isRumor      Boolean        @default(false)
  confidence   NewsConfidence @default(HIGH)
  status       RecordStatus   @default(PUBLISHED)
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  mentions NewsMention[]

  @@index([publishedAt])
  @@index([category])
  @@index([status])
  @@index([sourceUrl])
}

model NewsMention {
  id             String          @id @default(cuid())
  newsItemId     String
  newsItem       NewsItem        @relation(fields: [newsItemId], references: [id], onDelete: Cascade)
  mentionType    NewsMentionType
  label          String
  confidence     NewsConfidence  @default(HIGH)
  reason         String?
  companyId      String?
  company        Company?        @relation(fields: [companyId], references: [id])
  fundId         String?
  fund           Fund?           @relation(fields: [fundId], references: [id])
  organizationId String?
  organization   Organization?   @relation(fields: [organizationId], references: [id])
  dealId         String?
  deal           Deal?           @relation(fields: [dealId], references: [id])
  createdAt      DateTime        @default(now())

  @@unique([newsItemId, mentionType, label])
  @@index([newsItemId])
  @@index([companyId])
  @@index([fundId])
  @@index([organizationId])
  @@index([dealId])
  @@index([mentionType])
}

// ── Daily Infrastructure M&A Conditions Dashboard ───────

model DashboardMetricDefinition {
  id             String   @id
  label          String
  section        String
  group          String
  unit           String?
  format         String   @default("number")
  cadence        String   @default("daily")
  sourceId       String
  sourceName     String
  sourceUrl      String?
  sourceKind     String   @default("official")
  description    String   @default("")
  staleAfterDays Int      @default(7)
  status         String   @default("ACTIVE")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  observations DashboardObservation[]

  @@index([section])
  @@index([sourceId])
  @@index([status])
}

model DashboardObservation {
  id          String   @id @default(cuid())
  metricId    String
  metric      DashboardMetricDefinition @relation(fields: [metricId], references: [id], onDelete: Cascade)
  sourceId    String
  sourceRunId String?
  observedAt  DateTime
  periodEnd   DateTime
  value       Float?
  textValue   String?
  unit        String?
  status      String   @default("CACHED")
  metadata    Json?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([metricId, periodEnd, sourceId])
  @@index([metricId, periodEnd])
  @@index([sourceId])
  @@index([status])
}

enum DashboardSignalReviewStatus {
  PENDING
  APPROVED
  REJECTED
}

model DashboardSignal {
  id                  String                      @id @default(cuid())
  signalKey           String
  section             String
  title               String
  summary             String                      @default("")
  direction           String                      @default("NEEDS_REVIEW")
  severity            Int                         @default(1)
  observedAt          DateTime
  sourceId            String
  sourceName          String
  sourceUrl           String?
  sourceRunId         String?
  sourceRun           DashboardSourceRun?         @relation(fields: [sourceRunId], references: [id], onDelete: SetNull)
  reviewStatus        DashboardSignalReviewStatus @default(PENDING)
  reviewedAt          DateTime?
  reviewedById        String?
  reviewedBy          User?                       @relation("DashboardSignalReviewer", fields: [reviewedById], references: [id], onDelete: SetNull)
  contentHash         String                      @default("")
  reviewedContentHash String?
  metadata            Json?
  createdAt           DateTime                    @default(now())
  updatedAt           DateTime                    @updatedAt

  @@unique([signalKey, observedAt, sourceId])
  @@index([section])
  @@index([sourceId])
  @@index([sourceRunId])
  @@index([direction])
  @@index([reviewStatus, observedAt])
  @@index([reviewedById])
  @@index([observedAt])
}

model DashboardSourceRun {
  id                   String   @id @default(cuid())
  sourceId             String
  sourceName           String
  status               String
  startedAt            DateTime
  endedAt              DateTime?
  observationsFetched  Int      @default(0)
  observationsUpserted Int      @default(0)
  signalsFetched       Int      @default(0)
  signalsUpserted      Int      @default(0)
  error                String?
  metadata             Json?
  createdAt            DateTime @default(now())

  signals DashboardSignal[]

  @@index([sourceId])
  @@index([status])
  @@index([startedAt])
}

// ── User ───────────────────────────────────────────────

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String?
  role         UserRole @default(SUBSCRIBER)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  reviewedDashboardSignals DashboardSignal[] @relation("DashboardSignalReviewer")
}

model AuthThrottle {
  keyHash         String   @id
  failedAttempts  Int      @default(0)
  windowStartedAt DateTime @default(now())
  lockedUntil     DateTime?
  updatedAt       DateTime @updatedAt

  @@index([lockedUntil])
}
