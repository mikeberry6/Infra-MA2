{
  "name": "infra-tracker",
  "version": "1.0.0",
  "private": true,
  "packageManager": "npm@11.11.0",
  "engines": {
    "node": "24.x",
    "npm": "11.x"
  },
  "scripts": {
    "dev": "next dev",
    "postinstall": "prisma generate",
    "build": "next build",
    "start": "next start",
    "lint": "eslint src prisma scripts next.config.js --ext .js,.jsx,.ts,.tsx",
    "typecheck": "tsc --noEmit",
    "db:validate": "prisma validate",
    "audit:prod": "npm audit --omit=dev --audit-level=high",
    "test": "vitest run",
    "test:watch": "vitest",
    "doctor": "npx tsx scripts/doctor.ts",
    "dashboard:sync": "npx tsx scripts/dashboard-sync.ts",
    "dashboard:sync:dry-run": "npx tsx scripts/dashboard-sync.ts --dry-run",
    "dashboard:seed-sample": "npx tsx scripts/dashboard-seed-sample.ts",
    "dashboard:verify": "npx tsx scripts/dashboard-verify.ts",
    "news:scan": "npx tsx scripts/news-scan.ts",
    "news:scan:dry-run": "npx tsx scripts/news-scan.ts --dry-run",
    "research:full-universe-prompt": "npx tsx scripts/research/build-full-universe-prompt.ts",
    "audit:portfolio-years": "node --experimental-strip-types scripts/audit-portfolio-investment-years.ts",
    "audit:portfolio-fund-ownership": "node --experimental-strip-types scripts/audit-portfolio-fund-ownership.ts",
    "audit:portfolio-milestones": "node --experimental-strip-types scripts/audit-portfolio-milestones.ts",
    "curate:portfolio-milestones": "node --experimental-strip-types scripts/curate-portfolio-milestones.ts",
    "reconcile:portfolio-milestones": "npx tsx scripts/reconcile-portfolio-milestones.ts",
    "validate-portfolios": "node --experimental-strip-types scripts/validate-portfolios.ts",
    "validate-weekly-email": "node --experimental-strip-types scripts/validate-weekly-email.ts",
    "db:seed": "npx tsx prisma/seed.ts",
    "db:verify": "npx tsx prisma/verify-seed.ts",
    "db:sync-weekly-deals": "npx tsx scripts/sync-weekly-briefing-deals.ts",
    "db:sync-weekly-deals:apply": "npx tsx scripts/sync-weekly-briefing-deals.ts --apply",
    "db:generate": "npx prisma generate",
    "db:migrate": "npx prisma migrate dev",
    "db:studio": "npx prisma studio",
    "admin:create": "npx tsx scripts/create-admin.ts"
  },
  "dependencies": {
    "@neondatabase/serverless": "^1.1.0",
    "@prisma/adapter-neon": "7.9.0",
    "@prisma/adapter-pg": "7.9.0",
    "@prisma/client": "7.9.0",
    "@vercel/analytics": "^2.0.1",
    "@vercel/speed-insights": "^2.0.0",
    "bcryptjs": "^3.0.3",
    "lucide-react": "0.453.0",
    "next": "15.5.21",
    "next-auth": "4.24.15",
    "pg": "^8.20.0",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^24.0.0",
    "@types/pg": "^8.20.0",
    "@types/react": "18.3.3",
    "@types/react-dom": "18.3.0",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/ui": "^4.1.5",
    "autoprefixer": "10.4.19",
    "dotenv": "^17.4.1",
    "eslint": "^8.57.1",
    "eslint-config-next": "15.5.21",
    "exceljs": "^4.4.0",
    "jsdom": "^29.0.2",
    "postcss": "8.5.21",
    "prisma": "7.9.0",
    "tailwindcss": "3.4.4",
    "tsx": "^4.23.1",
    "typescript": "5.4.5",
    "vitest": "^4.1.5"
  },
  "overrides": {
    "postcss": "8.5.21",
    "sharp": "0.35.0"
  }
}
