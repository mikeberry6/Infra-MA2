# Database
DATABASE_URL=
DATABASE_URL_UNPOOLED=
# Optional non-sensitive fallback when a hosted runtime does not expose a
# unique VERCEL_DEPLOYMENT_ID. Set a unique value for every deployment at both
# build and runtime; never put a connection string or credential here.
DATA_CACHE_NAMESPACE=
# Required before any script is allowed to write. Use exact non-secret host/database identifiers.
EXPECTED_DATABASE_HOST=
EXPECTED_DATABASE_NAME=
FORBIDDEN_DATABASE_HOST=
FORBIDDEN_DATABASE_HOST_2=
TARGET_DATABASE=development
# Maintenance apply modes also require the reviewed commit, reviewer, and reason.
RELEASE_SHA=
MUTATION_REVIEWED_BY=
MUTATION_REASON=

# Auth
# NextAuth v4 requires the complete auth API endpoint. Keep the retained
# application base path, for example: https://example.com/Infra-MA2/api/auth
NEXTAUTH_URL=
NEXTAUTH_SECRET=
NEXT_PUBLIC_SITE_URL=

# Explicit administrator bootstrap (ordinary seeding never creates users)
ADMIN_EMAIL=
ADMIN_PASSWORD=
ADMIN_NAME=

# Browser/integration verification (use an isolated migrated database branch)
E2E_DATABASE_URL=
E2E_ADMIN_EMAIL=
E2E_ADMIN_PASSWORD=
PLAYWRIGHT_BASE_URL=
E2E_BASE_PATH=/Infra-MA2

# Vercel / Neon integration variables may also be present locally after
# `vercel env pull`, but they should not be committed with values.
DATABASE_NEON_PROJECT_ID=
DATABASE_PGHOST=
DATABASE_PGHOST_UNPOOLED=
DATABASE_PGDATABASE=
DATABASE_PGUSER=
DATABASE_PGPASSWORD=

# Dashboard data providers
# Treasury, Federal Register, and USAspending run without keys.
DASHBOARD_WRITES_ENABLED=false
FRED_API_KEY=
EIA_API_KEY=
SAM_API_KEY=
SEC_USER_AGENT=
SEC_WATCHLIST_CIKS=
DASHBOARD_MANUAL_IMPORT_PATH=
